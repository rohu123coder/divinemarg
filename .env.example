# PostgreSQL (matches docker-compose defaults; override in production)
DATABASE_URL=postgresql://divinemarg:divinemarg@localhost:5432/divinemarg

# Redis
REDIS_URL=redis://localhost:6379

# Backend auth
JWT_SECRET=change-me-to-a-long-random-string

# Razorpay
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# B2B demo booking admin alerts (optional)
ADMIN_NOTIFY_EMAIL=admin@divinemarg.com
RESEND_API_KEY=

# Web B2B landing (apps/web/.env.local)
# NEXT_PUBLIC_RAZORPAY_PAYMENT_PAGE_URL=https://rzp.io/rzp/divinemarg-demo
# NEXT_PUBLIC_META_PIXEL_ID=477011361415427
# NEXT_PUBLIC_GA4_MEASUREMENT_ID=G-XXXXXXXXXX
# NEXT_PUBLIC_API_URL=https://divinemarg.onrender.com

# Firebase Admin — JSON string of the service account key, or path handled by your app
FIREBASE_SERVICE_ACCOUNT=

# NextAuth (web & admin apps)
NEXTAUTH_SECRET=change-me-to-a-long-random-string
