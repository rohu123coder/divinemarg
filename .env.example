# PostgreSQL (matches docker-compose defaults; override in production)
DATABASE_URL=postgresql://divinemarg:divinemarg@localhost:5432/divinemarg

# Redis
REDIS_URL=redis://localhost:6379

# Backend auth
JWT_SECRET=change-me-to-a-long-random-string

# Razorpay
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# Firebase Admin — JSON string of the service account key, or path handled by your app
FIREBASE_SERVICE_ACCOUNT=

# NextAuth (web & admin apps)
NEXTAUTH_SECRET=change-me-to-a-long-random-string
