{
  "name": "divinemarg-platform",
  "private": true,
  "workspaces": [
    "apps/*",
    "backend",
    "shared"
  ],
  "scripts": {
    "dev:web": "npm run dev --workspace=divinemarg-web",
    "dev:admin": "npm run dev --workspace=divinemarg-admin",
    "dev:backend": "npm run dev --workspace=divinemarg-backend",
    "dev:mobile": "npm run start --workspace=divinemarg-mobile",
    "build": "npm run build --workspaces --if-present"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "devDependencies": {
    "ajv": "^8.18.0"
  },
  "dependencies": {
    "agora-rtc-sdk-ng": "^4.24.3",
    "agora-token": "^2.0.5",
    "react": "19.1.0",
    "react-dom": "19.1.0"
  },
  "overrides": {
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "@types/react": "19.1.0"
  },
  "resolutions": {
    "react": "19.1.0",
    "react-dom": "19.1.0"
  }
}
