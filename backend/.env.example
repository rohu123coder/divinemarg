# DivineMarg Backend — environment variables
# Copy to .env and fill in values for local development.

DATABASE_URL=postgresql://divinemarg:divinemarg@localhost:5432/divinemarg
REDIS_URL=redis://localhost:6379
JWT_SECRET=change-me-to-a-long-random-string

# Cloudinary (profile & reading photo uploads)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Anthropic Claude (Hand & Face Reading vision analysis)
ANTHROPIC_API_KEY=

# Razorpay
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# Email (Resend)
RESEND_API_KEY=
ADMIN_NOTIFY_EMAIL=admin@divinemarg.com

# SMS OTP (Fast2SMS)
FAST2SMS_API_KEY=

# Agora voice/video
AGORA_APP_ID=
AGORA_APP_CERTIFICATE=

# Frontend URL (password reset links, etc.)
FRONTEND_URL=http://localhost:3000

PORT=4000
