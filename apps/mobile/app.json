{
  "expo": {
    "name": "DivineMarg",
    "slug": "divinemarg",
    "scheme": "divinemarg",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#FFFFFF"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#FFFFFF"
      },
      "package": "com.divinemarg.app",
      "newArchEnabled": false
    },
    "ios": {
      "bundleIdentifier": "com.divinemarg.app",
      "supportsTablet": false
    },
    "plugins": [
      "./plugins/withFixReactNative77AppGradle.js",
      "expo-router",
      "expo-font",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#FFFFFF",
          "image": "./assets/splash-icon.png",
          "imageWidth": 200
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "dcc29648-0c17-42a3-a0fc-ec927c23f9af"
      }
    },
    "owner": "rohu2502"
  }
}
